{
  "name": "servicenow-backend",
  "version": "1.0.0",
  "description": "Express proxy backend for ServiceNow REST API integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "dotenv -- concurrently \"npm run dev:css\" \"npm run dev:js\" \"npm run dev:server\"",
    "dev:css": "tailwindcss -i ./src/style.css -o ./style.css --watch",
    "dev:js": "esbuild src/index.jsx --bundle --outfile=app.js --define:process.env.GEMINI_API_KEY=\"'%GEMINI_API_KEY%'\" --watch",
    "dev:server": "nodemon server.js",
    "build": "node build.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.4",
    "tailwindcss": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
